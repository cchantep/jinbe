# Routes
# This file defines all application routes (Higher priority routes first)
# ~~~~

# Application's entry point
GET           /                                                   io.github.cchantep.jinbe.demo.controllers.JinbeController.index

GET           /api/buckets                                        io.github.cchantep.jinbe.demo.controllers.JinbeController.listBuckets
+ nocsrf
POST          /api/buckets/:bucketName                            io.github.cchantep.jinbe.demo.controllers.JinbeController.createBucket(bucketName: String)
+ nocsrf
DELETE        /api/buckets/:bucketName                            io.github.cchantep.jinbe.demo.controllers.JinbeController.deleteBucket(bucketName: String)

GET           /api/buckets/:bucketName/objects                    io.github.cchantep.jinbe.demo.controllers.JinbeController.listObjects(bucketName: String)
GET           /api/buckets/:bucketName/objects/:objectName        io.github.cchantep.jinbe.demo.controllers.JinbeController.getObject(bucketName: String, objectName: String)
HEAD /api/buckets/:bucketName/objects/:objectName                 io.github.cchantep.jinbe.demo.controllers.JinbeController.objectMetadata(bucketName: String, objectName: String)
+ nocsrf
POST          /api/buckets/:bucketName/objects                    io.github.cchantep.jinbe.demo.controllers.JinbeController.createObject(bucketName: String)
+ nocsrf
DELETE        /api/buckets/:bucketName/objects/:objectName        io.github.cchantep.jinbe.demo.controllers.JinbeController.deleteObject(bucketName: String, objectName: String)


# Map static resources from the /public folder to the /assets URL path
GET           /assets/*file                                       controllers.Assets.versioned(path="/public", file: Asset)